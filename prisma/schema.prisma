  gradientType      String? @map("gradient_type") // linear | radial
  gradientDirection String? @map("gradient_direction") // to bottom | 135deg | etc.
  gradientColors    Json?   @map("gradient_colors") // [{color, position}]

  // Image / Video
  imageUrl   String? @map("image_url")
  videoUrl   String? @map("video_url")
  bgPosition String? @default("center") @map("bg_position")
  bgSize     String? @default("cover") @map("bg_size")
  bgRepeat   String? @default("no-repeat") @map("bg_repeat")

