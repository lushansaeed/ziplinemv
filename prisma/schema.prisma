// ─── Prisma Schema — Zipline MV ─────────────────────────────────────────────
// Supabase PostgreSQL · Role-based · Multi-portal · Future-proof (activities)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  BOOKING_STAFF
  MEDIA_STAFF
  FINANCE
  AGENT
  AFFILIATE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingSource {
  DIRECT
  WALK_IN
  AGENT
  AFFILIATE
}

enum CustomerType {
  LOCAL
  TOURIST
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  PARTIALLY_LAUNCHED
  PARTIALLY_LANDED
  COMPLETED
  COMPLETED_WITH_REMARKS
  CANCELLED
  NO_SHOW
  WEATHER_CANCELLED
  RESCHEDULED
  REFUNDED
}

enum ScanLocation {
  FIRST_FLOOR
  THIRD_FLOOR
  FIFTH_FLOOR
  LANDING_TOWER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
}

enum WristbandStatus {
  AVAILABLE
  ACTIVE
  COMPLETED
  DAMAGED
  LOST
}

enum RiderTrackingStatus {
  PENDING
  CHECKED_IN
  FIRST_FLOOR
  THIRD_FLOOR
  LAUNCHED
  LANDED
  DID_NOT_FLY
  WEATHER_CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
  FAILED
  COMPLIMENTARY
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
  PAYMENT_LINK
  COMPLIMENTARY
}

enum WaiverStatus {
  PENDING
  SIGNED
  EXEMPTED
}

enum MediaDeliveryStatus {
  NOT_APPLICABLE
  PENDING
  PROCESSING
  UPLOADED
  SENT_TO_CUSTOMER
  ISSUE_REPORTED
  REFUNDED
  RESOLVED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PolicyType {
  TERMS_AND_CONDITIONS
  REFUND_POLICY
  IMPORTANT_INFORMATION
  PRIVACY_POLICY
}

enum PricingRuleType {
  TOURIST
  LOCAL
  CHILD
  GROUP
  AGENT
  WALK_IN
  SEASONAL
  DATE_SPECIFIC
  TIME_SPECIFIC
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CommissionBasis {
  PACKAGE_ONLY
  PACKAGE_AND_ADDONS
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
}

enum SlotStatus {
  AVAILABLE
  FULL
  BLOCKED
  WEATHER_CLOSED
  EVENT_CLOSED
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLATION
  WAIVER_LINK
  WAIVER_REMINDER
  MEDIA_DELIVERY
  AGENT_APPROVAL
  AFFILIATE_APPROVAL
  PAYMENT_RECEIVED
  REFUND_PROCESSED
  ADMIN_NEW_BOOKING
  AFFILIATE_CONVERSION
}

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  supabaseUid String?    @unique @map("supabase_uid")
  email       String     @unique
  name        String
  role        UserRole   @default(BOOKING_STAFF)
  staffRoleId String?    @map("staff_role_id")
  staffRole   StaffRole? @relation(fields: [staffRoleId], references: [id])
  status      UserStatus @default(ACTIVE)
  avatarUrl   String?    @map("avatar_url")
  phone       String?
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  agent           Agent?
  affiliate       Affiliate?
  bookingsCreated Booking[]               @relation("CreatedBy")
  auditLogs       AuditLog[]
  mediaUploads    WebsiteMedia[]
  checkIns        CheckIn[]               @relation("CheckedInBy")
  mediaAssigned   CustomerMediaDelivery[] @relation("AssignedTo")
  payoutRequests  PayoutRequest[]

  @@index([role, status])
  @@index([staffRoleId, status])
  @@index([createdAt])
  @@map("users")
}

model StaffRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isAdmin     Boolean  @default(false) @map("is_admin")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@index([active, isAdmin])
  @@map("staff_roles")
}

model RolePermission {
  id        String    @id @default(cuid())
  roleId    String    @map("role_id")
  role      StaffRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String
  action    String
  allowed   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([roleId, module, action])
  @@index([module, action])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  role      String?
  action    String
  module    String
  recordId  String?  @map("record_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@index([module, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENTS
// ─────────────────────────────────────────────────────────────────────────────

model AgentApplication {
  id                      String            @id @default(cuid())
  businessName            String            @map("business_name")
  contactPerson           String            @map("contact_person")
  email                   String
  phone                   String
  island                  String?
  businessType            String?           @map("business_type")
  address                 String?
  website                 String?
  expectedMonthlyBookings Int?              @map("expected_monthly_bookings")
  documentsUrls           String[]          @map("documents_urls")
  agreementAccepted       Boolean           @default(false) @map("agreement_accepted")
  status                  ApplicationStatus @default(PENDING)
  adminNotes              String?           @map("admin_notes")
  submittedAt             DateTime          @default(now()) @map("submitted_at")
  reviewedAt              DateTime?         @map("reviewed_at")

  agent Agent?

  @@map("agent_applications")
}

model Agent {
  id                     String            @id @default(cuid())
  userId                 String            @unique @map("user_id")
  user                   User              @relation(fields: [userId], references: [id])
  applicationId          String?           @unique @map("application_id")
  application            AgentApplication? @relation(fields: [applicationId], references: [id])
  businessName           String            @map("business_name")
  contactPerson          String            @map("contact_person")
  email                  String
  phone                  String
  island                 String?
  businessType           String?           @map("business_type")
  address                String?
  website                String?
  commissionRate         Decimal           @default(10) @map("commission_rate") @db.Decimal(5, 2)
  commissionBasis        CommissionBasis   @default(PACKAGE_ONLY) @map("commission_basis")
  touristCommissionType  DiscountType?     @map("tourist_commission_type")
  touristCommissionValue Decimal?          @map("tourist_commission_value") @db.Decimal(10, 2)
  localCommissionType    DiscountType?     @map("local_commission_type")
  localCommissionValue   Decimal?          @map("local_commission_value") @db.Decimal(10, 2)
  addOnCommissionType    DiscountType?     @map("add_on_commission_type")
  addOnCommissionValue   Decimal?          @map("add_on_commission_value") @db.Decimal(10, 2)
  canMakeUnpaidBookings  Boolean           @default(false) @map("can_make_unpaid_bookings")
  specialPricing         Json?             @map("special_pricing")
  status                 ApplicationStatus @default(PENDING)
  approvedAt             DateTime?         @map("approved_at")
  notes                  String?
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  bookings         Booking[]
  customers        Customer[]
  commissions      AgentCommission[]
  addOnCommissions AgentAddOnCommission[]

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
  @@map("agents")
}

model AgentAddOnCommission {
  id         String        @id @default(cuid())
  agentId    String        @map("agent_id")
  agent      Agent         @relation(fields: [agentId], references: [id])
  addOnId    String        @map("add_on_id")
  addOn      AddOn         @relation(fields: [addOnId], references: [id])
  type       DiscountType
  value      Decimal       @db.Decimal(10, 2)
  localType  DiscountType? @map("local_type")
  localValue Decimal?      @map("local_value") @db.Decimal(10, 2)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@unique([agentId, addOnId])
  @@index([agentId])
  @@index([addOnId])
  @@map("agent_add_on_commissions")
}

model AgentCommission {
  id        String          @id @default(cuid())
  bookingId String          @unique @map("booking_id")
  booking   Booking         @relation(fields: [bookingId], references: [id])
  agentId   String          @map("agent_id")
  agent     Agent           @relation(fields: [agentId], references: [id])
  amount    Decimal         @db.Decimal(10, 2)
  rate      Decimal         @db.Decimal(5, 2)
  basis     CommissionBasis
  breakdown Json?
  status    PayoutStatus    @default(PENDING)
  paidAt    DateTime?       @map("paid_at")
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([agentId])
  @@index([agentId, status])
  @@index([status, createdAt])
  @@map("agent_commissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AFFILIATES
// ─────────────────────────────────────────────────────────────────────────────

model AffiliateApplication {
  id                String            @id @default(cuid())
  name              String
  contactPerson     String            @map("contact_person")
  email             String
  phone             String
  website           String?
  promotionChannel  String?           @map("promotion_channel")
  expectedTraffic   String?           @map("expected_traffic")
  preferredCoupon   String?           @map("preferred_coupon")
  paymentDetails    Json?             @map("payment_details")
  agreementAccepted Boolean           @default(false) @map("agreement_accepted")
  status            ApplicationStatus @default(PENDING)
  adminNotes        String?           @map("admin_notes")
  submittedAt       DateTime          @default(now()) @map("submitted_at")
  reviewedAt        DateTime?         @map("reviewed_at")

  affiliate Affiliate?

  @@map("affiliate_applications")
}

model Affiliate {
  id              String                @id @default(cuid())
  userId          String                @unique @map("user_id")
  user            User                  @relation(fields: [userId], references: [id])
  applicationId   String?               @unique @map("application_id")
  application     AffiliateApplication? @relation(fields: [applicationId], references: [id])
  name            String
  contactPerson   String                @map("contact_person")
  email           String
  phone           String
  website         String?
  channel         String?
  commissionRate  Decimal               @default(5) @map("commission_rate") @db.Decimal(5, 2)
  commissionBasis CommissionBasis       @default(PACKAGE_ONLY) @map("commission_basis")
  cookieDays      Int                   @default(30) @map("cookie_days")
  paymentDetails  Json?                 @map("payment_details")
  status          ApplicationStatus     @default(PENDING)
  approvedAt      DateTime?             @map("approved_at")
  notes           String?
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  links       AffiliateLink[]
  coupons     AffiliateCoupon[]
  bookings    Booking[]
  customers   Customer[]
  commissions AffiliateCommission[]

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
  @@map("affiliates")
}

model AffiliateLink {
  id          String    @id @default(cuid())
  affiliateId String    @map("affiliate_id")
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  slug        String    @unique
  fullUrl     String    @map("full_url")
  label       String?
  active      Boolean   @default(true)
  clickCount  Int       @default(0) @map("click_count")
  createdAt   DateTime  @default(now()) @map("created_at")

  clicks AffiliateClick[]

  @@index([affiliateId])
  @@index([affiliateId, active])
  @@map("affiliate_links")
}

model AffiliateCoupon {
  id            String            @id @default(cuid())
  affiliateId   String            @map("affiliate_id")
  affiliate     Affiliate         @relation(fields: [affiliateId], references: [id])
  code          String            @unique
  discountType  DiscountType      @map("discount_type")
  discountValue Decimal           @map("discount_value") @db.Decimal(10, 2)
  maxUses       Int?              @map("max_uses")
  usedCount     Int               @default(0) @map("used_count")
  status        ApplicationStatus @default(PENDING)
  approvedAt    DateTime?         @map("approved_at")
  validFrom     DateTime?         @map("valid_from")
  validTo       DateTime?         @map("valid_to")
  createdAt     DateTime          @default(now()) @map("created_at")

  clicks   AffiliateClick[]
  bookings Booking[]

  @@index([affiliateId])
  @@index([affiliateId, status])
  @@index([status, createdAt])
  @@map("affiliate_coupons")
}

model AffiliateClick {
  id          String           @id @default(cuid())
  linkId      String?          @map("link_id")
  link        AffiliateLink?   @relation(fields: [linkId], references: [id])
  couponId    String?          @map("coupon_id")
  coupon      AffiliateCoupon? @relation(fields: [couponId], references: [id])
  sessionId   String?          @map("session_id")
  ipAddress   String?          @map("ip_address")
  userAgent   String?          @map("user_agent")
  referrer    String?
  convertedAt DateTime?        @map("converted_at")
  bookingId   String?          @unique @map("booking_id")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([linkId])
  @@index([couponId])
  @@index([sessionId])
  @@index([convertedAt])
  @@map("affiliate_clicks")
}

model AffiliateCommission {
  id          String          @id @default(cuid())
  bookingId   String          @unique @map("booking_id")
  booking     Booking         @relation(fields: [bookingId], references: [id])
  affiliateId String          @map("affiliate_id")
  affiliate   Affiliate       @relation(fields: [affiliateId], references: [id])
  amount      Decimal         @db.Decimal(10, 2)
  rate        Decimal         @db.Decimal(5, 2)
  basis       CommissionBasis
  status      PayoutStatus    @default(PENDING)
  paidAt      DateTime?       @map("paid_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([affiliateId])
  @@index([affiliateId, status])
  @@index([status, createdAt])
  @@map("affiliate_commissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS & RIDERS
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String
  phoneCountry String        @default("MV") @map("phone_country")
  email        String?
  nationality  String?
  hotel        String?
  source       BookingSource @default(DIRECT)
  agentId      String?       @map("agent_id")
  agent        Agent?        @relation(fields: [agentId], references: [id])
  affiliateId  String?       @map("affiliate_id")
  affiliate    Affiliate?    @relation(fields: [affiliateId], references: [id])
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  bookings Booking[]
  riders   Rider[]

  @@index([agentId])
  @@index([affiliateId])
  @@index([source, createdAt])
  @@index([phone])
  @@index([email])
  @@index([createdAt])
  @@map("customers")
}

model Rider {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])
  name       String
  age        Int?
  weight     Decimal? @db.Decimal(5, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  bookingRiders BookingRider[]
  waivers       Waiver[]

  @@index([customerId])
  @@map("riders")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITIES (future-proof: zipline → snorkelling, sunset cruise, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  packages      Package[]
  addOns        AddOn[]
  timeSlots     TimeSlot[]
  slotTemplates SlotTemplate[]

  @@map("activities")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOG — PACKAGES & ADD-ONS
// ─────────────────────────────────────────────────────────────────────────────

model Package {
  id                          String        @id @default(cuid())
  activityId                  String        @map("activity_id")
  activity                    Activity      @relation(fields: [activityId], references: [id])
  name                        String
  slug                        String        @unique
  description                 String?
  touristPrice                Decimal       @map("tourist_price") @db.Decimal(10, 2)
  localPrice                  Decimal?      @map("local_price") @db.Decimal(10, 2) // legacy USD local price
  localPriceMvr               Decimal?      @map("local_price_mvr") @db.Decimal(10, 2) // MVR price for Maldivian residents
  childPrice                  Decimal?      @map("child_price") @db.Decimal(10, 2)
  currency                    String        @default("USD")
  included                    String[]
  excluded                    String[]
  featured                    Boolean       @default(false)
  imageUrl                    String?       @map("image_url")
  videoUrl                    String?       @map("video_url")
  packageTerms                String?       @map("package_terms")
  maxParticipants             Int?          @map("max_participants")
  agentCommissionEligible     Boolean       @default(true) @map("agent_commission_eligible")
  agentCommissionType         DiscountType? @map("agent_commission_type")
  agentCommissionValue        Decimal?      @map("agent_commission_value") @db.Decimal(10, 2)
  affiliateCommissionEligible Boolean       @default(true) @map("affiliate_commission_eligible")
  displayOrder                Int           @default(0) @map("display_order")
  active                      Boolean       @default(true)
  createdAt                   DateTime      @default(now()) @map("created_at")
  updatedAt                   DateTime      @updatedAt @map("updated_at")

  bookings     PricingRule[]
  bookingsList Booking[]

  @@index([active, displayOrder])
  @@index([activityId, active])
  @@map("packages")
}

model AddOn {
  id                      String        @id @default(cuid())
  activityId              String        @map("activity_id")
  activity                Activity      @relation(fields: [activityId], references: [id])
  name                    String
  description             String?
  price                   Decimal       @db.Decimal(10, 2) // USD price for tourists
  localPriceMvr           Decimal?      @map("local_price_mvr") @db.Decimal(10, 2) // MVR price for locals
  currency                String        @default("USD")
  mediaUrl                String?       @map("media_url")
  bestFor                 String?       @map("best_for")
  rules                   String?
  agentCommissionEligible Boolean       @default(true) @map("agent_commission_eligible")
  agentCommissionType     DiscountType? @map("agent_commission_type")
  agentCommissionValue    Decimal?      @map("agent_commission_value") @db.Decimal(10, 2)
  displayOrder            Int           @default(0) @map("display_order")
  active                  Boolean       @default(true)
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  bookingAddOns    BookingAddOn[]
  agentCommissions AgentAddOnCommission[]

  @@index([active, displayOrder])
  @@index([activityId, active])
  @@map("add_ons")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICING ENGINE
// ─────────────────────────────────────────────────────────────────────────────

model PricingRule {
  id        String          @id @default(cuid())
  packageId String?         @map("package_id")
  package   Package?        @relation(fields: [packageId], references: [id])
  ruleType  PricingRuleType @map("rule_type")
  appliesTo String?         @map("applies_to")
  valueType DiscountType    @map("value_type")
  value     Decimal         @db.Decimal(10, 4)
  priority  Int             @default(0)
  dateStart DateTime?       @map("date_start")
  dateEnd   DateTime?       @map("date_end")
  active    Boolean         @default(true)
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([packageId])
  @@map("pricing_rules")
}

model PromoCode {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType @map("discount_type")
  discountValue  Decimal      @map("discount_value") @db.Decimal(10, 2)
  maxUses        Int?         @map("max_uses")
  usedCount      Int          @default(0) @map("used_count")
  minOrderAmount Decimal?     @map("min_order_amount") @db.Decimal(10, 2)
  validFrom      DateTime?    @map("valid_from")
  validTo        DateTime?    @map("valid_to")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")

  bookings Booking[]

  @@map("promo_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// TIME SLOTS
// ─────────────────────────────────────────────────────────────────────────────

model SlotTemplate {
  id                  String   @id @default(cuid())
  activityId          String   @map("activity_id")
  activity            Activity @relation(fields: [activityId], references: [id])
  dayOfWeek           Int      @map("day_of_week") // 0=Sun..6=Sat
  isActive            Boolean  @default(true) @map("is_active")
  startTime           String   @map("start_time") // "09:00"
  endTime             String   @map("end_time") // "18:00"
  breakStartTime      String?  @map("break_start_time") // "12:30"
  breakEndTime        String?  @map("break_end_time") // "13:30"
  slotIntervalMinutes Int      @default(30) @map("slot_interval_minutes") // 15|30|45|60
  capacity            Int      @default(8)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([activityId, dayOfWeek])
  @@map("slot_templates")
}

model DateSlotOverride {
  id                  String   @id @default(cuid())
  activityId          String   @map("activity_id")
  date                DateTime @db.Date
  overrideType        String   @map("override_type") // closed|custom_hours|custom_break|custom_interval|custom_capacity
  isClosed            Boolean  @default(false) @map("is_closed")
  startTime           String?  @map("start_time")
  endTime             String?  @map("end_time")
  breakStartTime      String?  @map("break_start_time")
  breakEndTime        String?  @map("break_end_time")
  slotIntervalMinutes Int?     @map("slot_interval_minutes")
  capacityPerSlot     Int?     @map("capacity_per_slot")
  notes               String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([activityId, date])
  @@map("date_slot_overrides")
}

model BlockedSlot {
  id            String   @id @default(cuid())
  activityId    String   @map("activity_id")
  date          DateTime @db.Date
  slotStartTime String   @map("slot_start_time")
  slotEndTime   String   @map("slot_end_time")
  reason        String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([activityId, date])
  @@map("blocked_slots")
}

model TimeSlot {
  id            String     @id @default(cuid())
  activityId    String     @map("activity_id")
  activity      Activity   @relation(fields: [activityId], references: [id])
  date          DateTime   @db.Date
  startTime     String     @map("start_time")
  endTime       String     @map("end_time")
  capacity      Int        @default(8)
  bookedCount   Int        @default(0) @map("booked_count")
  status        SlotStatus @default(AVAILABLE)
  priceOverride Decimal?   @map("price_override") @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime   @default(now()) @map("created_at")

  bookings Booking[]

  @@unique([activityId, date, startTime])
  @@index([date])
  @@index([date, status])
  @@index([activityId, date, status])
  @@map("time_slots")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id                         String              @id @default(cuid())
  reference                  String              @unique
  customerId                 String              @map("customer_id")
  customer                   Customer            @relation(fields: [customerId], references: [id])
  agentId                    String?             @map("agent_id")
  agent                      Agent?              @relation(fields: [agentId], references: [id])
  affiliateId                String?             @map("affiliate_id")
  affiliate                  Affiliate?          @relation(fields: [affiliateId], references: [id])
  affiliateCouponId          String?             @map("affiliate_coupon_id")
  affiliateCoupon            AffiliateCoupon?    @relation(fields: [affiliateCouponId], references: [id])
  promoCodeId                String?             @map("promo_code_id")
  promoCode                  PromoCode?          @relation(fields: [promoCodeId], references: [id])
  packageId                  String              @map("package_id")
  package                    Package             @relation(fields: [packageId], references: [id])
  slotId                     String              @map("slot_id")
  slot                       TimeSlot            @relation(fields: [slotId], references: [id])
  slotLabel                  String?             @map("slot_label") // "09:00 to 09:30" — stored for display
  bookingDate                DateTime            @map("booking_date") @db.Date
  numRiders                  Int                 @map("num_riders")
  source                     BookingSource       @default(DIRECT)
  customerType               CustomerType        @default(TOURIST) @map("customer_type")
  subtotal                   Decimal             @db.Decimal(10, 2)
  discountAmount             Decimal             @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total                      Decimal             @db.Decimal(10, 2)
  currency                   String              @default("USD")
  exchangeRate               Decimal?            @map("exchange_rate") @db.Decimal(10, 4)
  priceType                  String?             @map("price_type")
  paymentStatus              PaymentStatus       @default(UNPAID) @map("payment_status")
  paymentMethod              PaymentMethod?      @map("payment_method")
  bookingStatus              BookingStatus       @default(CONFIRMED) @map("booking_status")
  waiverStatus               WaiverStatus        @default(PENDING) @map("waiver_status")
  mediaStatus                MediaDeliveryStatus @default(NOT_APPLICABLE) @map("media_status")
  qrCode                     String?             @map("qr_code")
  confirmationEmailSent      Boolean             @default(false) @map("confirmation_email_sent")
  confirmationEmailSentAt    DateTime?           @map("confirmation_email_sent_at")
  confirmationEmailError     String?             @map("confirmation_email_error") @db.Text
  confirmationEmailRecipient String?             @map("confirmation_email_recipient")
  notes                      String?
  createdById                String?             @map("created_by")
  createdBy                  User?               @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt                  DateTime            @default(now()) @map("created_at")
  updatedAt                  DateTime            @updatedAt @map("updated_at")

  riders              BookingRider[]
  addOns              BookingAddOn[]
  payments            Payment[]
  refunds             Refund[]
  waivers             Waiver[]
  waiverLinks         BookingWaiverLink[]
  checkIn             CheckIn?
  mediaDelivery       CustomerMediaDelivery?
  agentCommission     AgentCommission?
  affiliateCommission AffiliateCommission?
  rideTrackings       RideTracking[]
  rescheduleHistory   RescheduleHistory[]
  scanEvents          ScanEvent[]

  @@index([customerId])
  @@index([agentId])
  @@index([affiliateId])
  @@index([bookingDate])
  @@index([bookingStatus])
  @@index([source])
  @@index([bookingDate, bookingStatus])
  @@index([bookingDate, paymentStatus])
  @@index([source, paymentStatus, createdAt])
  @@index([currency, paymentStatus, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([mediaStatus, createdAt])
  @@index([waiverStatus, bookingDate])
  @@index([createdAt])
  @@map("bookings")
}

model BookingRider {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  booking   Booking  @relation(fields: [bookingId], references: [id])
  riderId   String?  @map("rider_id")
  rider     Rider?   @relation(fields: [riderId], references: [id])
  name      String
  age       Int?
  weight    Decimal? @db.Decimal(5, 2)

  rideTracking RideTracking?

  @@index([bookingId])
  @@index([riderId])
  @@map("booking_riders")
}

model BookingAddOn {
  id           String  @id @default(cuid())
  bookingId    String  @map("booking_id")
  booking      Booking @relation(fields: [bookingId], references: [id])
  addOnId      String  @map("add_on_id")
  addOn        AddOn   @relation(fields: [addOnId], references: [id])
  quantity     Int     @default(1)
  pricePerUnit Decimal @map("price_per_unit") @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  @@index([bookingId])
  @@index([addOnId])
  @@map("booking_add_ons")
}

model Waiver {
  id                          String             @id @default(cuid())
  bookingId                   String             @map("booking_id")
  booking                     Booking            @relation(fields: [bookingId], references: [id])
  waiverLinkId                String?            @map("waiver_link_id")
  waiverLink                  BookingWaiverLink? @relation(fields: [waiverLinkId], references: [id])
  riderId                     String?            @map("rider_id")
  rider                       Rider?             @relation(fields: [riderId], references: [id])
  riderName                   String             @map("rider_name")
  nationality                 String?
  dateOfBirth                 DateTime?          @map("date_of_birth") @db.Date
  isMinor                     Boolean            @default(false) @map("is_minor")
  phoneCountryCode            String?            @map("phone_country_code")
  phoneNumber                 String?            @map("phone_number")
  guardianName                String?            @map("guardian_name")
  guardianPhone               String?            @map("guardian_phone")
  guardianRelationship        String?            @map("guardian_relationship")
  guardianDeclarationAccepted Boolean            @default(false) @map("guardian_declaration_accepted")
  guardianSignatureData       String?            @map("guardian_signature_data")
  emergencyContactName        String?            @map("emergency_contact_name")
  emergencyContactPhone       String?            @map("emergency_contact_phone")
  weight                      Decimal?           @db.Decimal(5, 2)
  healthDeclarationAnswers    Json?              @map("health_declaration_answers")
  riskAcknowledged            Boolean            @default(false) @map("risk_acknowledged")
  safetyRulesAcknowledged     Boolean            @default(false) @map("safety_rules_acknowledged")
  mediaConsent                Boolean            @default(false) @map("media_consent")
  signatureData               String?            @map("signature_data")
  signedAt                    DateTime?          @map("signed_at")
  ipAddress                   String?            @map("ip_address")
  userAgent                   String?            @map("user_agent")
  deviceInfo                  String?            @map("device_info")
  submissionMode              String?            @map("submission_mode")
  staffAssisted               Boolean            @default(false) @map("staff_assisted")
  status                      WaiverStatus       @default(PENDING)
  createdAt                   DateTime           @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([waiverLinkId])
  @@index([bookingId, status])
  @@index([status, createdAt])
  @@index([phoneNumber])
  @@map("waivers")
}

model BookingWaiverLink {
  id                 String    @id @default(cuid())
  bookingId          String    @map("booking_id")
  booking            Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  token              String    @unique
  maxSubmissions     Int       @map("max_submissions")
  currentSubmissions Int       @default(0) @map("current_submissions")
  isActive           Boolean   @default(true) @map("is_active")
  createdByAgentId   String?   @map("created_by_agent_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  regeneratedAt      DateTime? @map("regenerated_at")
  expiresAt          DateTime? @map("expires_at")

  waivers Waiver[]

  @@index([bookingId])
  @@index([token])
  @@map("booking_waiver_links")
}

model Payment {
  id         String        @id @default(cuid())
  bookingId  String        @map("booking_id")
  booking    Booking       @relation(fields: [bookingId], references: [id])
  amount     Decimal       @db.Decimal(10, 2)
  currency   String        @default("USD")
  method     PaymentMethod
  reference  String?
  gatewayRef String?       @unique @map("gateway_ref")
  status     PaymentStatus
  metadata   Json?
  createdAt  DateTime      @default(now()) @map("created_at")

  refunds Refund[]

  @@index([bookingId])
  @@index([status, createdAt])
  @@index([currency, status, createdAt])
  @@index([method, status])
  @@map("payments")
}

model Refund {
  id         String       @id @default(cuid())
  bookingId  String       @map("booking_id")
  booking    Booking      @relation(fields: [bookingId], references: [id])
  paymentId  String?      @map("payment_id")
  payment    Payment?     @relation(fields: [paymentId], references: [id])
  amount     Decimal      @db.Decimal(10, 2)
  reason     String?
  status     PayoutStatus
  gatewayRef String?      @map("gateway_ref")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([paymentId])
  @@index([status, createdAt])
  @@map("refunds")
}

model CheckIn {
  id            String   @id @default(cuid())
  bookingId     String   @unique @map("booking_id")
  booking       Booking  @relation(fields: [bookingId], references: [id])
  checkedInAt   DateTime @default(now()) @map("checked_in_at")
  checkedInById String?  @map("checked_in_by")
  checkedInBy   User?    @relation("CheckedInBy", fields: [checkedInById], references: [id])
  notes         String?

  @@index([checkedInAt])
  @@index([checkedInById])
  @@map("check_ins")
}

