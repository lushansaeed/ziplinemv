model WebsiteTheme {
  id       String  @id @default(cuid())
  name     String  @default("Default Brand Theme")
  isActive Boolean @default(false) @map("is_active")

  // Brand colors
  primaryColor    String @default("#00A6B4") @map("primary_color")
  secondaryColor  String @default("#064E5F") @map("secondary_color")
  accentColor     String @default("#F6C85F") @map("accent_color")
  backgroundColor String @default("#F8FAF9") @map("background_color")
  textColor       String @default("#263238") @map("text_color")
  textMutedColor  String @default("#6B7280") @map("text_muted_color")
  buttonColor     String @default("#00A6B4") @map("button_color")
  buttonTextColor String @default("#FFFFFF") @map("button_text_color")
  headerBgColor   String @default("#FFFFFF") @map("header_bg_color")
  footerBgColor   String @default("#052F3F") @map("footer_bg_color")

  // Button style
  buttonRadius String @default("rounded-full") @map("button_radius")

  // Additional config as JSON (section styles etc.)
  config Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("website_themes")
}

model WebsiteBackground {
  id             String  @id @default(cuid())
  pageKey        String  @map("page_key") // home | packages | gallery | etc.
  sectionKey     String? @map("section_key") // hero | booking | faq | etc.
  backgroundType String  @default("solid") @map("background_type") // solid | gradient | image | video

  // Solid
