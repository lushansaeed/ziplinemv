  notes             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([deliveryStatus, createdAt])
  @@index([assignedToId, deliveryStatus])
  @@map("customer_media_delivery")
}

