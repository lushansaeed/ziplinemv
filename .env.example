# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Supabase serverless pooler connection (port 6543) — used at runtime
DATABASE_URL="postgresql://prisma.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres"
# Supabase direct connection (port 5432) — used for Prisma migrations
DIRECT_URL="postgresql://prisma.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres"

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="https://zipline.mv"
NEXT_PUBLIC_ADMIN_URL="https://admin.zipline.mv"
NEXT_PUBLIC_AGENT_URL="https://agents.zipline.mv"
NEXT_PUBLIC_AFFILIATE_URL="https://affiliate.zipline.mv"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@zipline.mv"
SMTP_PASSWORD=""
EMAIL_FROM="Zipline Maldives <noreply@zipline.mv>"

# ─── WhatsApp (Meta Business API) ────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-access-token"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id"

# ─── Odoo 19 (External API) ──────────────────────────────────────────────────
ODOO_SYNC_ENABLED="false"
ODOO_URL="https://your-company.odoo.com"
ODOO_DB="your_database"
ODOO_USERNAME="integration@zipline.mv"
ODOO_API_KEY="your-api-key"
# Product map for sale.order lines. Values are Odoo product.product IDs.
ODOO_PRODUCT_MAP='{"zipline_ride":2272,"insta360":2293,"photography":2294,"drone":2295,"discount":2296}'
ODOO_LOCAL_PRICELIST_ID=""
ODOO_TOURIST_PRICELIST_ID=""
# Optional fallback product for unmapped sale.order lines.
ODOO_DEFAULT_PRODUCT_ID=""
# Optional fallback product used for negative discount lines.
ODOO_DISCOUNT_PRODUCT_ID=""

# ─── Google Maps ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-maps-api-key"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CURRENCY="USD"
BOOKING_REF_PREFIX="ZL"
